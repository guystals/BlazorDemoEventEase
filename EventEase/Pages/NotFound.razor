@using Microsoft.AspNetCore.Components.Routing

<PageTitle>Page Not Found - EventEase</PageTitle>

<div class="not-found-page">
    <div class="not-found-container text-center">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
        </div>
        <h1 class="display-1 fw-bold">404</h1>
        <h2 class="mb-4">Page Not Found</h2>
        <p class="lead text-muted mb-4">
            Sorry, we couldn't find the page you're looking for. The page may have been moved or deleted.
        </p>

        <div class="not-found-actions">
            <a href="/" class="btn btn-primary btn-lg">
                <i class="bi bi-house-door"></i> Go to Home
            </a>
            <a href="/events" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-calendar-event"></i> Browse Events
            </a>
        </div>

        <div class="mt-5">
            <h5 class="text-muted">Quick Links</h5>
            <div class="quick-links mt-3">
                <a href="/" class="text-decoration-none me-3">
                    <i class="bi bi-house"></i> Home
                </a>
                <a href="/events" class="text-decoration-none me-3">
                    <i class="bi bi-calendar-event"></i> Events
                </a>
                <a href="/events/add" class="text-decoration-none">
                    <i class="bi bi-plus-circle"></i> Add Event
                </a>
            </div>
        </div>
    </div>
</div>