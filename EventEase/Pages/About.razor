@page "/about"

<PageTitle>About - EventEase</PageTitle>

<div class="about-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="bi bi-info-circle display-1 text-primary"></i>
                            <h1 class="mt-3">About EventEase</h1>
                        </div>

                        <div class="alert alert-info">
                            <p class="mb-0 fs-5 text-center">
                                This is an end project made for the <strong>"Blazor for front-end development"</strong> course.
                            </p>
                        </div>

                        <hr class="my-4" />

                        <div class="mt-4">
                            <h3 class="mb-3"><i class="bi bi-gear-fill text-primary"></i> Built With</h3>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Microsoft Copilot</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Blazor WebAssembly</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> .NET 10</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> Bootstrap 5</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success"></i> C# 13</li>
                            </ul>
                        </div>

                        <div class="mt-4">
                            <h3 class="mb-3"><i class="bi bi-star-fill text-warning"></i> Key Features</h3>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary"></i> Event Management System</li>
                                <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary"></i> Attendance Tracking</li>
                                <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary"></i> User Session Management</li>
                                <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary"></i> Repository Pattern Architecture</li>
                                <li class="mb-2"><i class="bi bi-arrow-right-circle text-primary"></i> Real-time Statistics</li>
                            </ul>
                        </div>

                        <div class="text-center mt-5">
                            <a href="/" class="btn btn-primary btn-lg">
                                <i class="bi bi-house-fill"></i> Back to Home
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
