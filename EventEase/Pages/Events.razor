@page "/events"
@using EventEase.Models
@using EventEase.Services
@using EventEase.Components
@inject IEventService EventService
@implements IDisposable

<PageTitle>Events - EventEase</PageTitle>

<div class="events-page">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1>Browse Events</h1>
                <p class="lead">Discover and register for upcoming corporate and social events</p>
            </div>
            <div>
                <a href="/events/add" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle"></i> Add New Event
                </a>
            </div>
        </div>
    </div>

    @* Search and Filter Section *@
    <div class="events-controls card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" 
                               class="form-control" 
                               placeholder="Search events by name or location..." 
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearch" />
                        @if (!string.IsNullOrWhiteSpace(searchTerm))
                        {
                            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedCategory" @bind:after="ApplyFiltersAsync">
                        <option value="">All Categories</option>
                        <option value="Technology">Technology</option>
                        <option value="Business">Business</option>
                        <option value="Social">Social</option>
                        <option value="Corporate">Corporate</option>
                        <option value="Education">Education</option>
                        <option value="Networking">Networking</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="sortOrder" @bind:after="ApplyFiltersAsync">
                        <option value="date-asc">Date (Earliest)</option>
                        <option value="date-desc">Date (Latest)</option>
                        <option value="name-asc">Name (A-Z)</option>
                        <option value="name-desc">Name (Z-A)</option>
                        <option value="capacity-desc">Capacity (High-Low)</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="itemsPerPage" @bind:after="ApplyFiltersAsync">
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                </div>
            </div>
            @if (events != null)
            {
                <div class="mt-2 text-muted small">
                    Showing @events.Count of @totalEventCount events
                </div>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading events...</p>
        </div>
    }
    else if (events == null || !events.Any())
    {
        <div class="alert alert-info">
            @if (totalEventCount == 0 && string.IsNullOrWhiteSpace(searchTerm) && string.IsNullOrWhiteSpace(selectedCategory))
            {
                <p>No events available at the moment. Please check back later.</p>
                <a href="/events/add" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Your First Event
                </a>
            }
            else
            {
                <p>No events found matching your search criteria.</p>
                <button class="btn btn-primary" @onclick="ClearAllFilters">
                    <i class="bi bi-arrow-counterclockwise"></i> Clear Filters
                </button>
            }
        </div>
    }
    else
    {
        @* Event Grid with Pagination *@
        <div class="events-grid">
            @foreach (var evt in events)
            {
                <EventCard Event="@evt" @key="evt.Id" />
            }
        </div>

        @* Pagination Controls *@
        @if (totalPages > 1)
        {
            <nav aria-label="Event pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1)">
                            <i class="bi bi-chevron-double-left"></i>
                        </button>
                    </li>
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                    </li>

                    @foreach (var pageNum in GetPageNumbers())
                    {
                        var pageNumber = pageNum;
                        <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                            <button class="page-link" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage == totalPages)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => GoToPage(totalPages)" disabled="@(currentPage == totalPages)">
                            <i class="bi bi-chevron-double-right"></i>
                        </button>
                    </li>
                </ul>
                <div class="text-center text-muted">
                    Page @currentPage of @totalPages
                </div>
            </nav>
        }
    }
</div>

@code {
    private List<Event>? events;
    private bool isLoading = true;
    private int totalEventCount = 0;

    // Filtering and Search
    private string searchTerm = string.Empty;
    private string selectedCategory = string.Empty;
    private string sortOrder = "date-asc";

    // Pagination
    private int currentPage = 1;
    private int itemsPerPage = 25;
    private int totalPages => totalEventCount > 0
        ? (int)Math.Ceiling(totalEventCount / (double)itemsPerPage)
        : 1;

    // Debouncing
    private CancellationTokenSource? debounceCancellation;
    private const int DebounceDelayMs = 300;

    protected override async Task OnInitializedAsync()
    {
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        isLoading = true;
        try
        {
            await ApplyFiltersAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleSearch()
    {
        debounceCancellation?.Cancel();
        debounceCancellation?.Dispose();
        debounceCancellation = new CancellationTokenSource();
        _ = DebounceSearchAsync(debounceCancellation.Token);
    }

    private async Task DebounceSearchAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(DebounceDelayMs, cancellationToken);
            await InvokeAsync(async () =>
            {
                await ApplyFiltersAsync();
                StateHasChanged();
            });
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ApplyFiltersAsync()
    {
        currentPage = 1;
        await LoadCurrentPageAsync();
    }

    private async Task LoadCurrentPageAsync()
    {
        var (pagedEvents, totalCount) = await EventService.GetPagedEventsAsync(
            currentPage,
            itemsPerPage,
            searchTerm,
            selectedCategory,
            sortOrder);

        events = pagedEvents;
        totalEventCount = totalCount;
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        await LoadCurrentPageAsync();
    }

    private IEnumerable<int> GetPageNumbers()
    {
        const int maxVisiblePages = 5;
        var startPage = Math.Max(1, currentPage - maxVisiblePages / 2);
        var endPage = Math.Min(totalPages, startPage + maxVisiblePages - 1);

        if (endPage - startPage < maxVisiblePages - 1)
        {
            startPage = Math.Max(1, endPage - maxVisiblePages + 1);
        }

        return Enumerable.Range(startPage, endPage - startPage + 1);
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        await ApplyFiltersAsync();
    }

    private async Task ClearAllFilters()
    {
        searchTerm = string.Empty;
        selectedCategory = string.Empty;
        sortOrder = "date-asc";
        await ApplyFiltersAsync();
    }

    public void Dispose()
    {
        debounceCancellation?.Cancel();
        debounceCancellation?.Dispose();
    }
}
