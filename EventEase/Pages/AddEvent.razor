@page "/events/add"
@using EventEase.Models
@using EventEase.Services
@inject IEventService EventService
@inject NavigationManager Navigation
@inject ILogger<AddEvent> Logger

<PageTitle>Add New Event - EventEase</PageTitle>

<div class="add-event-page">
    <div class="page-header">
        <h1>Create New Event</h1>
        <p class="lead">Add a new corporate or social event</p>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="@eventForm" OnValidSubmit="@HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label for="eventName" class="form-label">Event Name *</label>
                            <InputText id="eventName" class="form-control" @bind-Value="eventForm.Name" placeholder="Enter event name" />
                            <ValidationMessage For="@(() => eventForm.Name)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="eventDate" class="form-label">Event Date *</label>
                                <InputDate id="eventDate" class="form-control" @bind-Value="eventForm.Date" />
                                <ValidationMessage For="@(() => eventForm.Date)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="eventCategory" class="form-label">Category *</label>
                                <InputSelect id="eventCategory" class="form-select" @bind-Value="eventForm.Category">
                                    <option value="">-- Select Category --</option>
                                    <option value="Technology">Technology</option>
                                    <option value="Business">Business</option>
                                    <option value="Social">Social</option>
                                    <option value="Corporate">Corporate</option>
                                    <option value="Education">Education</option>
                                    <option value="Networking">Networking</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => eventForm.Category)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="eventLocation" class="form-label">Location *</label>
                            <InputText id="eventLocation" class="form-control" @bind-Value="eventForm.Location" placeholder="Enter event location" />
                            <ValidationMessage For="@(() => eventForm.Location)" />
                        </div>

                        <div class="mb-3">
                            <label for="eventCapacity" class="form-label">Capacity *</label>
                            <InputNumber id="eventCapacity" class="form-control" @bind-Value="eventForm.Capacity" placeholder="Maximum attendees" />
                            <ValidationMessage For="@(() => eventForm.Capacity)" />
                        </div>

                        <div class="mb-3">
                            <label for="eventDescription" class="form-label">Description *</label>
                            <InputTextArea id="eventDescription" class="form-control" rows="5" @bind-Value="eventForm.Description" placeholder="Enter event description" />
                            <ValidationMessage For="@(() => eventForm.Description)" />
                            <div class="form-text">
                                @eventForm.Description.Length / 1000 characters
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                }
                                <i class="bi bi-check-circle"></i> Create Event
                            </button>
                            <a href="/events" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>

            @if (showSuccessMessage)
            {
                <div class="alert alert-success mt-3">
                    <h5><i class="bi bi-check-circle-fill"></i> Success!</h5>
                    <p>Event "<strong>@createdEventName</strong>" has been created successfully.</p>
                    <a href="/events" class="btn btn-sm btn-primary">View All Events</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private EventFormModel eventForm = new EventFormModel();
    private bool isSubmitting = false;
    private bool showSuccessMessage = false;
    private string createdEventName = string.Empty;

    private async Task HandleSubmit()
    {
        isSubmitting = true;

        try
        {
            var newEvent = eventForm.ToEvent();
            var createdEvent = await EventService.AddEventAsync(newEvent);

            createdEventName = createdEvent.Name;
            showSuccessMessage = true;

            // Reset form for potential next entry
            eventForm = new EventFormModel();

            // Navigate to events list
            Navigation.NavigateTo("/events");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create event.");
            showSuccessMessage = false;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
