@page "/events/{id:int}"
@using EventEase.Models
@using EventEase.Services
@using EventEase.Components
@inject IEventService EventService
@inject UserSessionService SessionService
@inject IAttendanceService AttendanceService
@inject NavigationManager Navigation

<PageTitle>@(currentEvent?.Name ?? "Event Details") - EventEase</PageTitle>

<div class="event-details-page">
    @if (currentEvent == null)
    {
        @if (isLoading)
        {
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <h4>Event Not Found</h4>
                <p>The event you're looking for doesn't exist.</p>
                <a href="/events" class="btn btn-primary">Back to Events</a>
            </div>
        }
    }
    else
    {
        <div class="event-details-container">
            <div class="event-details-header">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1>@currentEvent.Name</h1>
                        <span class="badge bg-primary fs-6">@currentEvent.Category</span>
                    </div>
                    <a href="/events" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Events
                    </a>
                </div>
            </div>

            <div class="event-details-content">
                <div class="row">
                    <div class="col-md-8">
                        <RegistrationStatus EventId="@currentEvent.Id" />

                        <div class="card mb-4">
                            <div class="card-body">
                                <h3>Event Description</h3>
                                <p class="lead">@currentEvent.Description</p>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        <i class="bi bi-clipboard-check"></i> Attendance Summary
                                    </h5>
                                    <a href="@($"/attendance/{currentEvent.Id}")" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-box-arrow-up-right"></i> Manage Attendance
                                    </a>
                                </div>
                            </div>
                            <div class="card-body">
                                <AttendanceStats EventId="@currentEvent.Id" ShowExtendedStats="false" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Event Details</h5>
                                <hr />
                                <div class="event-info-item">
                                    <i class="bi bi-calendar-event text-primary"></i>
                                    <div>
                                        <strong>Date & Time</strong>
                                        <p>@currentEvent.Date.ToString("MMMM dd, yyyy")<br />
                                        @currentEvent.Date.ToString("hh:mm tt")</p>
                                    </div>
                                </div>
                                <div class="event-info-item">
                                    <i class="bi bi-geo-alt text-danger"></i>
                                    <div>
                                        <strong>Location</strong>
                                        <p>@currentEvent.Location</p>
                                    </div>
                                </div>
                                <div class="event-info-item">
                                    <i class="bi bi-people text-success"></i>
                                    <div>
                                        <strong>Capacity</strong>
                                        <p>@currentEvent.Capacity attendees</p>
                                    </div>
                                </div>
                                <hr />
                                <div class="d-grid gap-2">
                                    <a href="@($"/events/{currentEvent.Id}/register")" class="btn btn-success btn-lg">
                                        <i class="bi bi-pencil-square"></i> Register Now
                                    </a>
                                    <a href="@($"/events/{currentEvent.Id}/edit")" class="btn btn-warning">
                                        <i class="bi bi-pencil"></i> Edit Event
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? currentEvent;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        currentEvent = await EventService.GetEventByIdAsync(Id);
        isLoading = false;

        // Track that user viewed this event
        if (currentEvent != null)
        {
            SessionService.TrackEventView(currentEvent.Id);
        }
    }
}
