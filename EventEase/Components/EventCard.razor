@using EventEase.Models

<div class="event-card">
    <div class="event-card-header">
        <h3 class="event-name">@Event.Name</h3>
        <span class="event-category badge bg-primary">@Event.Category</span>
    </div>
    <div class="event-card-body">
        <div class="event-detail">
            <i class="bi bi-calendar-event"></i>
            <span class="event-date">@Event.Date.ToString("MMMM dd, yyyy - hh:mm tt")</span>
        </div>
        <div class="event-detail">
            <i class="bi bi-geo-alt"></i>
            <span class="event-location">@Event.Location</span>
        </div>
        <div class="event-description">
            <p>@Event.Description</p>
        </div>
        <div class="event-detail">
            <i class="bi bi-people"></i>
            <span class="event-capacity">Capacity: @Event.Capacity</span>
        </div>
    </div>
    <div class="event-card-footer">
        <a href="@($"/events/{Event.Id}")" class="btn btn-primary btn-sm">View Details</a>
        <a href="@($"/events/{Event.Id}/edit")" class="btn btn-warning btn-sm">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="@($"/events/{Event.Id}/register")" class="btn btn-success btn-sm">Register</a>
    </div>
</div>

@code {
    [Parameter]
    public Event Event { get; set; } = null!;
}
